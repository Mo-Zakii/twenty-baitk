    "scopes:sync": "tsx src/scripts/sync-lead-scopes.ts",
    "queue:sync": "tsx src/scripts/sync-distribution-queue.ts",
    "workspace:configure": "tsx src/scripts/configure-baitk-workspace.ts",
    "workspace:cleanup": "tsx src/scripts/cleanup-baitk-workspace-metadata.ts",
    "preinstall:mark": "tsx src/scripts/mark-baitk-preinstalled.ts",
