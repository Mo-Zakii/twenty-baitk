    "node": "^24.5.0",
    "npm": "please-use-yarn",
    "yarn": ">=4.0.2"
  },
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "twenty": "twenty",
    "lint": "oxlint -c .oxlintrc.json .",
    "lint:fix": "oxlint --fix -c .oxlintrc.json .",
    "test": "vitest run",
    "test:watch": "vitest",
